# ── LLM 백엔드 ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Agent 백엔드 선택: claude | local | gemini | openclaw
AGENT_BACKEND=claude
# 작업별 오버라이드 (선택)
# AGENT_BACKEND_WRITE=local
# AGENT_BACKEND_RESEARCH=claude
# 폴백 체인
# AGENT_FALLBACK=claude,local

# 로컬 Agent (집 서버 등)
# LOCAL_AGENT_URL=http://192.168.1.100:11434
# LOCAL_AGENT_TOKEN=
# LOCAL_AGENT_SCHEMA=openai   # openai | custom
# LOCAL_AGENT_MODEL=llama3

# ── Blogger ──────────────────────────────────────────
# Google OAuth2 인증 (API Key 아님)
# 최초 1회: python scripts/get_token.py 실행 → 브라우저 로그인 → token.json 생성
BLOG_MAIN_ID=                       # Blogger 블로그 ID (숫자)
# credentials.json = Google Cloud Console에서 다운받은 OAuth 클라이언트 파일
# token.json = get_token.py 실행 후 자동 생성 (gitignore 됨)

# ── Slack ────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_APPROVER_USER_IDS=U123456,U789012
PUBLIC_DASHBOARD_URL=http://localhost:8080

# ── 수익화 ───────────────────────────────────────────
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
ADSENSE_SLOT_TOP=1234567890
ADSENSE_SLOT_MID=0987654321
ADSENSE_SLOT_BOTTOM=1122334455

COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_TRACKING_ID=

# ── 이미지 생성 ───────────────────────────────────────
BANANAPRO_API_KEY=

# ── WordPress (선택) ─────────────────────────────────
WP_URL=
WP_USERNAME=
WP_APP_PASSWORD=

# ── 네이버 블로그 (선택) ──────────────────────────────
NAVER_BLOG_ENABLED=false
